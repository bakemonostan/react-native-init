{
  "name": "my-rn-template",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "start": "expo start",
    "start:staging": "APP_ENV=staging expo start --clear",
    "start:prod": "NODE_ENV=production APP_ENV=production expo start --clear",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "android:debug": "expo run:android --variant debug",
    "android:release": "expo run:android --variant release",
    "android:release:device": "expo run:android --variant release --device",
    "android:build": "expo run:android --device",
    "android:staging": "APP_ENV=staging expo run:android",
    "android:staging:debug": "APP_ENV=staging expo run:android --variant debug",
    "android:staging:release": "APP_ENV=staging expo run:android --variant release",
    "ios": "expo run:ios",
    "ios:staging": "APP_ENV=staging expo run:ios",
    "ios:prod-env": "NODE_ENV=production APP_ENV=production expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "bump-version": "node scripts/bump-version.js",
    "theme-mode": "node scripts/theme-mode.js"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@gorhom/bottom-sheet": "^5.1.5",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/drawer": "^7.3.9",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.6",
    "@tanstack/react-query": "^5.80.7",
    "ajv": "^8.17.1",
    "axios": "^1.9.0",
    "expo": "^55.0.15",
    "expo-blur": "~55.0.14",
    "expo-constants": "~55.0.14",
    "expo-dev-client": "~55.0.27",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.8",
    "expo-image-picker": "~55.0.18",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.13",
    "expo-localization": "~55.0.13",
    "expo-network": "~55.0.13",
    "expo-notifications": "~55.0.19",
    "expo-router": "~55.0.12",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.18",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.15",
    "expo-web-browser": "~55.0.14",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-toast-message": "^2.3.3",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "^0.7.0",
    "zod": "^3.25.64",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@tanstack/eslint-plugin-query": "^5.78.0",
    "@types/react": "^19.2.14",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "jest": "^29.2.1",
    "jest-expo": "~55.0.16",
    "react-test-renderer": "19.0.0",
    "typescript": "~5.9.2"
