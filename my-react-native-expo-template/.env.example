# Copy to `.env` — never commit real secrets.

APP_ENV=development
THEME_MODE=auto

# Optional brand accent — used when the full wizard token map below is not set.
EXPO_PUBLIC_BRAND_PRIMARY=#3B82F6

# Full semantic theme (RN Init wizard): EXPO_PUBLIC_THEME_LIGHT_* and EXPO_PUBLIC_THEME_DARK_*
# for BACKGROUND, FOREGROUND, CARD, PRIMARY, RING, CHART_1, … (see config/themeFromEnv.ts).


# Client state + HTTP (defaults match shipped code; RN Init wizard writes these too)
EXPO_PUBLIC_STATE_MODE=zustand
EXPO_PUBLIC_HTTP_CLIENT=axios+rq

APP_DISPLAY_NAME=my-rn-template
EXPO_PUBLIC_SLUG=my-rn-template
EXPO_PUBLIC_SCHEME=myrntemplate

EXPO_PUBLIC_API_BASE_URL=
EXPO_PUBLIC_API_BASE_URL_STAGING=

# Optional — RN Init wizard can set these when you choose a backend target:
# EXPO_PUBLIC_BACKEND_PROVIDER=none
# EXPO_PUBLIC_SUPABASE_URL=
# EXPO_PUBLIC_SUPABASE_ANON_KEY=

IOS_BUNDLE_ID=
IOS_BUNDLE_ID_STAGING=
ANDROID_PACKAGE=
ANDROID_PACKAGE_STAGING=

# mock = local success paths (default). api = calls services/authBackend.ts routes.
EXPO_PUBLIC_AUTH_MODE=mock

# 1 = request notification permission and log native push token in dev (no EAS required).
EXPO_PUBLIC_PUSH_SETUP=0

# Optional template modules (app.config extra → config/featureFlags.ts). 1/on = enabled, 0/false = off; omit = on.
EXPO_PUBLIC_ENABLE_TOAST=1
EXPO_PUBLIC_ENABLE_I18N=1
# When 0, EXPO_PUBLIC_STATE_MODE + EXPO_PUBLIC_HTTP_CLIENT are ignored (zustand + axios+rq).
EXPO_PUBLIC_ENABLE_FEATURE_FLAGS=1
EXPO_PUBLIC_ENABLE_DEBOUNCE=1
EXPO_PUBLIC_ENABLE_MEDIA_PERMISSIONS=1
EXPO_PUBLIC_ENABLE_KEYBOARD=1
EXPO_PUBLIC_ENABLE_DEEP_LINKING=1

# Optional: comma-separated hosts for Universal Links, e.g. app.example.com,www.example.com
# EXPO_PUBLIC_IOS_ASSOCIATED_DOMAINS=

EXPO_PUBLIC_APP_VERSION=
EXPO_PUBLIC_LOG_LEVEL=
